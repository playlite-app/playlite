use once_cell::sync::OnceCell;
use tauri::AppHandle;

static MASTER_KEY: OnceCell<[u8; 32]> = OnceCell::new();

// ============================================================
// CHAVE MESTRE FIXA
// ============================================================
// Esta função retorna uma chave mestre fixa de 32 bytes embutida no binário.
// Esta abordagem é simples e portável entre máquinas diferentes.
// Opcionalmente, pode modificar esta função para carregar a chave de um arquivo,
// ou implementar um sistema de gerenciamento de segredos mais robusto.
// ============================================================

pub fn master_key(_app: &AppHandle) -> Result<&'static [u8; 32], String> {
    MASTER_KEY.get_or_try_init(|| {
        // CHAVE FIXA DE EXEMPLO
        Ok([
            0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08,
            0x09, 0x0a, 0x0b, 0x0c, 0x0d, 0x0e, 0x0f, 0x10,
            0x11, 0x12, 0x13, 0x14, 0x15, 0x16, 0x17, 0x18,
            0x19, 0x1a, 0x1b, 0x1c, 0x1d, 0x1e, 0x1f, 0x20,
        ])
    })
}

// ============================================================
// API KEY DA ITAD (IsThereAnyDeal)
// ============================================================
// Obtenha uma API key gratuita em: https://isthereanydeal.com/apps/
//
// IMPORTANTE: Substitua "YOUR_ITAD_API_KEY_HERE" pela sua chave real
// ============================================================

const ITAD_API_KEY_RAW: &str = "YOUR_ITAD_API_KEY_HERE";

// Retorna a API Key da ITAD embutida no binário.
pub fn itad_api_key() -> &'static str {
    ITAD_API_KEY_RAW
}
