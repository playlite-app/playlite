use once_cell::sync::OnceCell;
use sha2::{Digest, Sha256};
use tauri::{AppHandle, Manager};
use tauri_plugin_machine_uid::MachineUidExt;

static MASTER_KEY: OnceCell<[u8; 32]> = OnceCell::new();

// Retorna a chave mestre derivada de dados únicos da máquina.
pub fn master_key(app: &AppHandle) -> Result<&'static [u8; 32], String> {
    MASTER_KEY.get_or_try_init(|| {
        let uid = app
            .machine_uid()
            .get_machine_uid()
            .map_err(|e| e.to_string())?
            .id
            .ok_or("Machine UID missing")?;

        let username = match whoami::username() {
            Ok(name) => name,
            Err(_) => "unknown_user".to_string(),
        };
        let app_id = app.config().identifier.clone();

        let mut hasher = Sha256::new();
        hasher.update(uid);
        hasher.update(username.as_bytes());
        hasher.update(app_id.as_bytes());

        let hash = hasher.finalize();
        let mut key = [0u8; 32];
        key.copy_from_slice(&hash[..32]);
        Ok(key)
    })
}

// ============================================================
// IMPORTANTE: Substitua a chave abaixo pela sua API Key real
// ============================================================
// Obtenha uma API key gratuita em: https://isthereanydeal.com/apps/
const ITAD_API_KEY_RAW: &str = "YOUR_ITAD_API_KEY_HERE";

// Retorna a API Key da ITAD embutida no binário.
pub fn itad_api_key() -> &'static str {
    ITAD_API_KEY_RAW
}

