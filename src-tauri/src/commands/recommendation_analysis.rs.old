//! Comandos para análise e debug do sistema de recomendação
//!
//! Este módulo fornece comandos Tauri para gerar relatórios de análise
//! do sistema de recomendação, úteis para debug e ajuste fino dos algoritmos.

use crate::database::AppState;
use crate::errors::AppError;
use crate::models::Game;
use crate::services::{recommendation, recommendation_analysis};
use serde::Serialize;
use std::collections::HashSet;
use tauri::{AppHandle, Manager, State};

/// Resposta do comando de análise
#[derive(Debug, Serialize)]
pub struct AnalysisResponse {
    pub success: bool,
    pub json_path: Option<String>,
    pub csv_path: Option<String>,
    pub txt_path: Option<String>,
    pub message: String,
}

/// Helper para buscar jogos com detalhes completos do banco
fn fetch_games_with_details(
    games: &[Game],
    state: &State<AppState>,
) -> Result<Vec<recommendation::GameWithDetails>, AppError> {
    let conn = state.library_db.lock()?;
    let game_ids: Vec<String> = games.iter().map(|g| g.id.clone()).collect();

    let placeholders = game_ids.iter().map(|_| "?").collect::<Vec<_>>().join(",");
    let query = format!(
        "SELECT
            g.id, g.name, g.cover_url, d.developer, g.platform, g.platform_id,
            g.install_path, g.executable_path, g.launch_args,
            g.user_rating, g.favorite, g.status, g.playtime, g.last_played, g.added_at,
            COALESCE(d.is_adult, 0),
            d.genres,
            d.tags,
            d.series,
            d.release_date,
            d.steam_app_id
         FROM games g
         LEFT JOIN game_details d ON g.id = d.game_id
         WHERE g.id IN ({})",
        placeholders
    );

    let mut stmt = conn.prepare(&query)?;
    let params: Vec<&dyn rusqlite::ToSql> = game_ids
        .iter()
        .map(|id| id as &dyn rusqlite::ToSql)
        .collect();

    let games_iter = stmt.query_map(params.as_slice(), |row| {
        let game = Game {
            id: row.get(0)?,
            name: row.get(1)?,
            cover_url: row.get(2)?,
            genres: None,
            developer: row.get(3)?,
            platform: row.get(4)?,
            platform_id: row.get(5)?,
            install_path: row.get(6)?,
            executable_path: row.get(7)?,
            launch_args: row.get(8)?,
            user_rating: row.get(9)?,
            favorite: row.get(10)?,
            status: row.get(11)?,
            playtime: row.get(12)?,
            last_played: row.get(13)?,
            added_at: row.get(14)?,
            is_adult: row.get(15)?,
        };

        let genres_str: Option<String> = row.get(16)?;
        let genres = genres_str
            .as_ref()
            .map(|s| {
                s.split(',')
                    .map(|g| g.trim().to_string())
                    .filter(|g| !g.is_empty() && g != "Desconhecido")
                    .collect()
            })
            .unwrap_or_default();

        let tags_json: Option<String> = row.get(17)?;
        let tags: Vec<crate::models::GameTag> = tags_json
            .as_ref()
            .and_then(|json| serde_json::from_str(json).ok())
            .unwrap_or_default();

        let series: Option<String> = row.get(18)?;
        let release_date: Option<String> = row.get(19)?;
        let release_year = release_date
            .as_ref()
            .and_then(|d| recommendation::parse_release_year(d));

        let steam_app_id: Option<String> = row.get(20)?;
        let steam_app_id = steam_app_id.and_then(|s| s.parse::<u32>().ok());

        Ok(recommendation::GameWithDetails {
            game,
            genres,
            tags,
            series,
            release_year,
            steam_app_id,
        })
    })?;

    Ok(games_iter.collect::<Result<Vec<_>, _>>()?)
}

/// Gera análise completa do sistema de recomendação
///
/// Cria três arquivos:
/// - `recommendation_analysis_TIMESTAMP.json` - Análise completa em JSON
/// - `recommendation_analysis_TIMESTAMP.txt` - Relatório legível em texto
/// - `recommendation_ranking_TIMESTAMP.csv` - Ranking em CSV para Excel
///
/// Os arquivos são salvos em `AppData/Local/Playlite/analysis/`
#[tauri::command]
pub async fn generate_recommendation_analysis(
    app: AppHandle,
    limit: Option<usize>,
) -> Result<AnalysisResponse, String> {
    tracing::info!("Gerando análise de recomendação...");

    // Configura diretório de análise
    let analysis_dir = app
        .path()
        .app_data_dir()
        .map_err(|e| format!("Erro ao obter diretório de dados: {}", e))?
        .join("analysis");

    std::fs::create_dir_all(&analysis_dir)
        .map_err(|e| format!("Erro ao criar diretório de análise: {}", e))?;

    let timestamp = chrono::Local::now().format("%Y%m%d_%H%M%S");
    let json_path = analysis_dir.join(format!("recommendation_analysis_{}.json", timestamp));
    let txt_path = analysis_dir.join(format!("recommendation_analysis_{}.txt", timestamp));
    let csv_path = analysis_dir.join(format!("recommendation_ranking_{}.csv", timestamp));

    // Busca dados
    let state: State<AppState> = app.state();
    let library_games = crate::commands::games::get_games(state.clone())
        .map_err(|e| format!("Erro ao buscar jogos da biblioteca: {}", e))?;

    tracing::info!("Total de jogos na biblioteca: {}", library_games.len());

    // Separa jogos já jogados vs candidatos
    let already_played_ids: HashSet<String> = library_games
        .iter()
        .filter(|g| {
            let hours = g.playtime.unwrap_or(0) as f32 / 60.0;
            hours > 5.0 || g.favorite
        })
        .map(|g| g.id.clone())
        .collect();

    let candidate_games: Vec<_> = library_games
        .iter()
        .filter(|g| !already_played_ids.contains(&g.id))
        .cloned()
        .collect();

    tracing::info!("Candidatos para recomendação: {}", candidate_games.len());

    // Converte para GameWithDetails
    let candidates_with_details = fetch_games_with_details(&candidate_games, &state)
        .map_err(|e| format!("Erro ao processar candidatos: {}", e))?;

    let all_games_with_details = fetch_games_with_details(&library_games, &state)
        .map_err(|e| format!("Erro ao processar biblioteca completa: {}", e))?;

    // Calcula perfil
    let ignored_ids: HashSet<String> = HashSet::new();
    let profile = recommendation::calculate_user_profile(&all_games_with_details, &ignored_ids);

    // Busca scores CF
    let (cf_scores, _) =
        crate::services::cf_aggregator::build_cf_candidates(&all_games_with_details);

    // Configura sistema
    let config = recommendation::RecommendationConfig::default();
    let user_settings = recommendation::UserSettings::default();

    // Gera relatório de análise
    let report = recommendation_analysis::generate_analysis_report(
        &profile,
        &candidates_with_details,
        &cf_scores,
        &ignored_ids,
        config,
        user_settings,
    );

    // Limita resultados se necessário
    let mut limited_report = report.clone();
    if let Some(limit) = limit {
        limited_report.games.truncate(limit);
    }

    // Exporta em todos os formatos
    recommendation_analysis::export_report_json(&limited_report, json_path.to_str().unwrap())
        .map_err(|e| format!("Erro ao salvar JSON: {}", e))?;

    recommendation_analysis::export_report_txt(&limited_report, txt_path.to_str().unwrap())
        .map_err(|e| format!("Erro ao salvar TXT: {}", e))?;

    recommendation_analysis::export_games_csv(&limited_report.games, csv_path.to_str().unwrap())
        .map_err(|e| format!("Erro ao salvar CSV: {}", e))?;

    tracing::info!("Análise gerada com sucesso!");
    tracing::info!("  JSON: {:?}", json_path);
    tracing::info!("  TXT:  {:?}", txt_path);
    tracing::info!("  CSV:  {:?}", csv_path);

    Ok(AnalysisResponse {
        success: true,
        json_path: Some(json_path.to_string_lossy().to_string()),
        txt_path: Some(txt_path.to_string_lossy().to_string()),
        csv_path: Some(csv_path.to_string_lossy().to_string()),
        message: format!(
            "Análise gerada com sucesso! {} jogos analisados.",
            limited_report.games.len()
        ),
    })
}
