{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Playlite",
  "version": "3.0.0",
  "identifier": "com.game-manager.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Playlite",
        "url": "index.html",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://cdn.cloudflare.steamstatic.com https://media.rawg.io; connect-src 'self' https://api.steampowered.com https://store.steampowered.com https://steamspy.com/api.php https://api.rawg.io https://api.isthereanydeal.com https://www.gamerpower.com https://generativelanguage.googleapis.com"
    }
  },
  "bundle": {
    "active": true,
    "copyright": "Copyright © 2026 Alan Goncalves",
    "targets": "msi",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Alan-oliveir/game_manager/releases/download/v3.0.0/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3MkZDMUI0MUMzRjUxNEIKUldSTFVUOGN0TUV2UjJKWUYvMEVuQnptbjE3bFpkYnA1ZnRnZkRJS1RkdVF2cHlOUC9jOEc3MFQK"
    }
  }
}
