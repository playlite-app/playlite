{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Playlite",
  "version": "3.2.8",
  "identifier": "com.game-manager.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Playlite",
        "label": "main",
        "url": "index.html",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https://cdn.cloudflare.steamstatic.com https://media.rawg.io https://*.gamerpower.com; connect-src 'self' https://api.steampowered.com https://store.steampowered.com https://steamspy.com/api.php https://api.rawg.io https://api.isthereanydeal.com https://*.gamerpower.com https://generativelanguage.googleapis.com"
    }
  },
  "bundle": {
    "active": true,
    "copyright": "Copyright © 2026 Alan Goncalves",
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/playlite-app/playlite/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzRUU4NzRDREQ4NDdCRjYKUldUMmU0VGRUSWZ1UXd5THJmb3J3S3A2UFJHcmpuZ2U0OWt6ZHhMU0RNSkx2bmh5Um40NEZYZDUK"
    }
  }
}
