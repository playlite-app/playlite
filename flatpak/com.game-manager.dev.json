{
  "app-id": "com.game-manager.dev",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "playlite",
  "finish-args": [
    "--share=network",
    "--share=ipc",

    "--socket=x11",
    "--socket=wayland",
    "--socket=pulseaudio",

    "--filesystem=home",
    "--filesystem=xdg-config",
    "--filesystem=xdg-data",

    "--device=dri"
  ],
  "modules": [
    {
      "name": "playlite",
      "buildsystem": "simple",
      "build-commands": [
        "npm install",
        "npm run build",
        "cargo build --release",
        "install -Dm755 src-tauri/target/release/playlite /app/bin/playlite",
        "install -Dm644 public/app-icon.png /app/share/icons/hicolor/256x256/apps/com.game-manager.dev.png"
      ],
      "sources": [
        {
          "type": "dir",
          "path": ".."
        }
      ]
    }
  ]
}
